<view class="register-container">
  <!-- 背景装饰 -->
  <view class="register-bg"></view>

  <!-- 注册内容 -->
  <view class="register-content">
    <!-- 顶部导航 -->
    <view class="register-nav">
      <text class="nav-back" bindtap="onGoToLogin">← 返回登录</text>
      <text class="nav-title">新用户注册</text>
      <view class="nav-placeholder"></view>
    </view>

    <!-- Logo区域 -->
    <view class="register-logo-section">
      <view class="logo-icon">📝</view>
      <text class="logo-title">欢迎加入</text>
      <text class="logo-subtitle">完成注册享受完整服务</text>
    </view>

    <!-- 错误提示 -->
    <view class="error-message" wx:if="{{errorMessage}}">
      <text class="error-icon">⚠️</text>
      <text class="error-text">{{errorMessage}}</text>
    </view>

    <!-- 成功提示 -->
    <view class="success-message" wx:if="{{successMessage}}">
      <text class="success-icon">✓</text>
      <text class="success-text">{{successMessage}}</text>
    </view>

    <!-- 注册表单 -->
    <view class="register-form">
      <!-- 步骤指示器 -->
      <view class="step-indicator">
        <view class="step {{currentStep >= 1 ? 'active' : ''}}">
          <text>1</text>
        </view>
        <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
        <view class="step {{currentStep >= 2 ? 'active' : ''}}">
          <text>2</text>
        </view>
        <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
        <view class="step {{currentStep >= 3 ? 'active' : ''}}">
          <text>3</text>
        </view>
      </view>

      <!-- 基本信息段 -->
      <view class="form-section" wx:if="{{currentStep === 1}}">
        <text class="section-title">基本信息</text>
        
        <view class="form-group">
          <label class="label">真实姓名 <text class="required">*</text></label>
          <view class="input-wrapper">
            <text class="input-icon">👤</text>
            <input
              class="input-field"
              type="text"
              placeholder="请输入您的真实姓名"
              value="{{realName}}"
              bindinput="onRealNameInput"
              placeholder-class="placeholder"
            />
          </view>
        </view>

        <view class="form-group">
          <label class="label">学号 <text class="required">*</text></label>
          <view class="input-wrapper">
            <text class="input-icon">🎓</text>
            <input
              class="input-field"
              type="text"
              placeholder="请输入您的学号"
              value="{{studentId}}"
              bindinput="onStudentIdInput"
              placeholder-class="placeholder"
            />
          </view>
        </view>

        <button class="btn btn-primary btn-lg" bindtap="onNextStep">
          下一步
        </button>
      </view>

      <!-- 联系方式段 -->
      <view class="form-section" wx:if="{{currentStep === 2}}">
        <text class="section-title">联系方式</text>
        
        <view class="form-group">
          <label class="label">手机号码 <text class="required">*</text></label>
          <view class="input-wrapper">
            <text class="input-icon">📱</text>
            <input
              class="input-field"
              type="tel"
              placeholder="请输入手机号码"
              value="{{phoneNumber}}"
              bindinput="onPhoneInput"
              maxlength="11"
              placeholder-class="placeholder"
            />
          </view>
        </view>

        <view class="form-actions">
          <button class="btn btn-secondary" bindtap="onPrevStep">上一步</button>
          <button class="btn btn-primary" bindtap="onNextStep">下一步</button>
        </view>
      </view>

      <!-- 密码段 -->
      <view class="form-section" wx:if="{{currentStep === 3}}">
        <text class="section-title">设置密码</text>
        
        <view class="form-group">
          <label class="label">密码 <text class="required">*</text></label>
          <view class="input-wrapper">
            <text class="input-icon">🔒</text>
            <input
              class="input-field"
              type="password"
              placeholder="至少8位，包含字母和数字"
              value="{{password}}"
              bindinput="onPasswordInput"
              placeholder-class="placeholder"
            />
          </view>
          <view class="password-strength" wx:if="{{password}}">
            <view class="strength-bar {{passwordStrength}}"></view>
            <text class="strength-text">强度：{{passwordStrengthText}}</text>
          </view>
        </view>

        <view class="form-group">
          <label class="label">确认密码 <text class="required">*</text></label>
          <view class="input-wrapper">
            <text class="input-icon">🔒</text>
            <input
              class="input-field"
              type="password"
              placeholder="请再次输入密码"
              value="{{confirmPassword}}"
              bindinput="onConfirmPasswordInput"
              placeholder-class="placeholder"
            />
          </view>
        </view>

        <view class="form-actions">
          <button class="btn btn-secondary" bindtap="onPrevStep">上一步</button>
          <button class="btn btn-primary btn-lg" bindtap="onRegister" wx:if="{{!isLoading}}">
            完成注册
          </button>
          <button class="btn btn-primary btn-lg disabled" wx:if="{{isLoading}}" disabled>
            注册中...
          </button>
        </view>
      </view>
    </view>

    <!-- 协议链接 -->
    <view class="footer-agreement">
      <text class="agreement-text">注册即代表同意 </text>
      <text class="agreement-link" bindtap="onShowAgreement">《用户协议》</text>
      <text class="agreement-text"> 和 </text>
      <text class="agreement-link" bindtap="onShowPrivacy">《隐私政策》</text>
    </view>
  </view>
</view>
