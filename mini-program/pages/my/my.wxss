.container {
  padding: 20rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
  padding-bottom: 60rpx;
  min-height: 100vh;
}

.content {
  padding-top: 20rpx;
}

.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.25);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.user-header {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255,255,255,0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 6rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.menu-section {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.menu-title {
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #262626;
  background: transparent;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-label {
  font-size: 28rpx;
  color: #666;
}

.menu-value {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 100rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff5252 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.3);
  color: white;
  border: none;
  border-radius: 20rpx;
  font-size: 30rpx;
  margin-top: 40rpx;
  font-weight: bold;
}

.logout-btn:active {
  opacity: 0.8;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.login-btn {
  display: inline-block;
  width: 200rpx;
  height: 80rpx;
  background: #667eea;
  color: white;
  text-align: center;
  line-height: 80rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

/* 标签切换样式 */
.tab-bar {
  display: flex;
  border-bottom: 1rpx solid #e8e8e8;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #999;
  border-bottom: 3rpx solid transparent;
}

.tab-item.active {
  color: #667eea;
  border-bottom-color: #667eea;
}

/* 预约列表样式 */
.reservation-list {
  padding: 20rpx 0;
}

.reservation-card {
  background: white;
  margin: 0 20rpx 15rpx 20rpx;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.reservation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.seat-info {
  flex: 1;
}

.seat-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.room-name {
  font-size: 24rpx;
  color: #999;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  color: white;
  font-size: 22rpx;
  font-weight: bold;
}

.reservation-body {
  margin: 15rpx 0;
  padding: 15rpx 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.info-row .label {
  color: #999;
}

.info-row .value {
  color: #333;
  font-weight: bold;
}

.reservation-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 15rpx;
}

.action-btn {
  flex: 1;
  height: 60rpx;
  padding: 0;
  border: 1rpx solid #ddd;
  background: white;
  border-radius: 6rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.cancel-btn:active {
  background: #fff1f0;
}

.check-in-btn {
  color: white;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.check-in-btn:active {
  opacity: 0.8;
}

.completed-btn {
  color: #999;
  border-color: #d9d9d9;
}

.empty-reservation {
  text-align: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
