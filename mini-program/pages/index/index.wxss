/* 首页样式 - 现代化设计 */
page {
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
}

.container {
  padding: 0;
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ===== 欢迎区域 ===== */
.welcome-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  padding: 60rpx 32rpx;
  color: white;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
  margin-bottom: 32rpx;
}

.greeting-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.greeting-title {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.greeting-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
  font-weight: 400;
}

/* ===== 菜单网格 ===== */
.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}

.menu-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

.menu-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.menu-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.menu-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
  display: block;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #262626;
  display: block;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.menu-arrow {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  font-size: 24rpx;
  color: #ccc;
  transition: all 0.3s ease;
}

.menu-card:active .menu-arrow {
  color: #667eea;
  transform: translateX(4rpx);
}

/* ===== 统计数据区域 ===== */
.stats-section {
  margin: 24rpx 16rpx;
  border-radius: 16rpx;
  background: white;
  border: 1rpx solid #f0f0f0;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.stat-item:active {
  background: linear-gradient(135deg, #e8eaef 0%, #e0e2e5 100%);
  transform: scale(1.02);
}

.stat-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  text-align: center;
}

/* ===== 公告卡片 ===== */
.announcement-card {
  margin: 24rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #fff4e6;
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.05) 0%, rgba(250, 173, 20, 0.02) 100%);
  transition: all 0.3s ease;
}

.announcement-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(250, 173, 20, 0.1);
}

.announcement-badge {
  display: inline-block;
  background: linear-gradient(135deg, #faad14 0%, #f59e0b 100%);
  color: white;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.announcement-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
  margin-bottom: 12rpx;
}

.announcement-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.announcement-time {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* ===== 底部提示 ===== */
.footer-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 32rpx 16rpx 20rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #e6f4ff 0%, #e6f7ff 100%);
  border-radius: 12rpx;
  border-left: 4rpx solid #1677dd;
}

.tip-icon {
  font-size: 28rpx;
  display: block;
}

.tip-text {
  font-size: 26rpx;
  color: #0050b3;
  flex: 1;
}

/* 动画类 */
.animate-slide-up {
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
